# ==============================================================
# Deep Research — 环境变量配置模板
# 复制为 .env 后填入真实值。.env 已被 .gitignore 排除，不会上传。
# ==============================================================

# --- 搜索引擎 (必选其一) ---
# hybrid = 自动尝试多个后端（推荐）
# duckduckgo / tavily / perplexity / searxng
SEARCH_API=hybrid

# --- 主 LLM (必填) ---
# 阿里云 DashScope（推荐）
LLM_MODEL_ID=qwen3.6-max-preview
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY 请在系统环境变量中设置

# 或者用本地 Ollama
# LLM_PROVIDER=ollama
# LLM_MODEL_ID=llama3:latest
# LLM_BASE_URL=http://localhost:11434/v1

# --- 备选 LLM（可选）—— 主 LLM 异常时自动降级 ---
# LLM_FALLBACK_PROVIDER=ollama
# LLM_FALLBACK_MODEL_ID=llama3:latest
# LLM_FALLBACK_BASE_URL=http://localhost:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434

# --- API Keys（推荐在系统环境变量中设置，不要写在这里！）---
# DASHSCOPE_API_KEY=sk-xxxxx     # 阿里云百炼: https://bailian.console.aliyun.com
# TAVILY_API_KEY=tvly-xxxxx      # Tavily 搜索: https://tavily.com
# SERPAPI_API_KEY=xxxxx          # SerpApi 搜索: https://serpapi.com

# --- 通用设置 ---
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=True

# --- 笔记 & 服务 ---
ENABLE_NOTES=True
NOTES_WORKSPACE=./notes
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
